# ======================================================
# 湘遇恋爱博客 - 环境变量配置
# 复制此文件为 .env 并修改相应值
# ======================================================

# ------------------------------------------------------
# 数据库配置
# ------------------------------------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_secure_password
DB_NAME=love_blog
DB_SSLMODE=disable

# ------------------------------------------------------
# JWT 配置（重要！请修改为强随机字符串）
# 生成命令：openssl rand -base64 32
# ------------------------------------------------------
JWT_SECRET=change_me_to_a_very_long_random_string_at_least_32_characters
JWT_EXPIRE_HOURS=72

# ------------------------------------------------------
# Redis 配置（可选）
# ------------------------------------------------------
REDIS_ADDR=redis:6379

# ------------------------------------------------------
# CORS 配置（生产环境请修改为实际域名）
# ------------------------------------------------------
ALLOW_ORIGINS=http://localhost:5700

# ------------------------------------------------------
# 应用配置
# ------------------------------------------------------
APP_ENV=production

# ------------------------------------------------------
# 前端端口（访问地址：http://IP:5700）
# ------------------------------------------------------
# 在 docker-compose.yml 中配置端口映射
