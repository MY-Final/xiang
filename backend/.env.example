APP_PORT=8979

# Option A: one-line connection string (recommended for remote DB)
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/love_blog?sslmode=disable

# Option B: split config (used when DATABASE_URL is empty)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=love_blog
DB_SSLMODE=disable

JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=168

UPLOAD_DIR=uploads
