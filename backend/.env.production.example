# 生产环境变量配置
# 复制此文件为 .env.production 并修改相应值

# 应用配置
APP_ENV=production
APP_PORT=8979

# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_NAME=love_blog
DB_SSLMODE=disable

# 或者使用完整 DSN
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=disable

# JWT 配置（请修改为强随机字符串）
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRE_HOURS=72

# Redis 配置（可选）
REDIS_ADDR=localhost:6379

# 文件上传
UPLOAD_DIR=uploads

# CORS 配置（生产环境请修改为实际域名）
ALLOW_ORIGINS=http://localhost:6100,https://yourdomain.com
